# Copy this file to .env and fill in your values
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# For Render.com PostgreSQL, paste your DATABASE_URL here:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GMAIL SMTP SETUP - Required for Account Activation & Password Reset
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# IMPORTANT: You MUST use a Google App Password, NOT your Gmail password!
# 
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your device)
# 3. Google will generate a 16-character app password
# 4. Paste it below (it looks like: "nggu tecr mdtc jnoq")
#
# These settings enable:
# - Account activation emails after registration
# - Password reset emails when users forget their password
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Email timeout configuration - properly passed to SMTP backend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=xxxxxxxxxxxx
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=KitchenOQ <your-gmail-address@gmail.com>

FRONTEND_URL=http://localhost:5173
