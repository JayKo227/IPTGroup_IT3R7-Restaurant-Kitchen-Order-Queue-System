# Copy this file to .env and fill in your values
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# For Render.com PostgreSQL, paste your DATABASE_URL here:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Gmail SMTP settings for activation/reset emails
# Use a Google App Password for EMAIL_HOST_PASSWORD
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL="KitchenOQ <your-gmail-address@gmail.com>"
FRONTEND_URL=http://localhost:5173
